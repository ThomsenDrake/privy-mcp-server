# Privy Configuration
PRIVY_APP_ID=your_app_id
PRIVY_APP_SECRET=your_app_secret
PRIVY_API_BASE_URL=https://api.privy.io/v1
PRIVY_AUTHORIZATION_PRIVATE_KEY=your_optional_authorization_key

# Optional: Bearer token authentication for remote deployments
# When set, all requests must include a valid bearer token
# MCP_AUTH_TOKEN=your_secret_token

# Optional: Set to use HTTP transport instead of stdio (auto-enabled when PORT is set)
# MCP_TRANSPORT=http
# PORT=3000